{ "name": "user-repository",
  "version":
    "0.0.1",
  "description":
    "Decentralized, distributed, permissionless, uncensorable, undeletable, unstoppable, User Repository and Application Store.",
  "funding": {
    "type":
      "patreon",
    "url":
      "https://patreon.com/tallero"
  },
  "man": [
    "./man/ur.1"
  ],
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "README.md",
    "dist",
    "lib",
    "libur",
    "libur.webpack.config.js",
    "ur",
    "fs-worker.webpack.config.js",
    "package.json",
    "serve.json",
    "webpack.config.js"
  ],
  "keywords": [
    "ur",
    "themartiancompany",
    "dogeos",
    "ethereum",
    "evmfs",
    "openpgp-on-ethereum"
  ],
  "homepage":
    "https://github.com/themartiancompany/ur",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/ur.js/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/ur.js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author": {
    "name":
      "Pellegrino Prevete",
    "email":
      "pellegrinoprevete@gmail.com",
    "url":
      "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.10",
    "flatted":
      "^3.2.9",
    "eslint":
      "^10.0.3",
    "globals":
      "^17.3.0",
    "@eslint/js":
      "^10.0.1",
    "safely-serve":
      "^0.0.9",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "crash-js":
      "^0.1.111",
    "evmfs":
      "^0.0.6",
    "yargs":
      "18.0.0"
  },
  "optionalDependencies": {
  },
  "type":
    "commonjs",
  "main":
    "libur",
  "bin":
    { 
      "ur":
        "ur",
      "ur.js":
        "ur"
    },
  "yargs": {
    "parse-numbers":
      false,
    "parse-positional-numbers":
      false
  },
  "scripts": {
    "build-bin":
      "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mv 'ur.js' 'dist/ur'",
    "build-fs-worker":
      "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details && cp 'fs-worker.js' 'dist/ur' && cp 'fs-worker.js' 'dist/libur'",
    "build-lib":
      "npx webpack --mode 'production' --config 'libur.webpack.config.cjs' --stats-error-details && mv 'libur.js' 'dist/libur'",
    "build":
      "npm run lint && npm run build-fs-worker && npm run build-lib && npm run build-bin",
    "lint":
      "npx eslint .",
    "publish-npm":
      "npm run build && npm publish --access public",
    "start":
      "npx safely-serve 'dist/ur' --port 3000 --https --no-cache",
    "test":
      "echo \"Error: no test specified\" && exit 1"
  }
}
